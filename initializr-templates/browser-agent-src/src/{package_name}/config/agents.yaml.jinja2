# AgentScope Browser Agent Configuration
# Generated for {{ name }}

agents:
  - name: {{ name }}
    type: {{ agent_type.value }}
    model_provider: {{ model_provider.value }}
    {% if model_provider.value == "openai" %}
    model: {{ openai_model | default("gpt-4") }}
    {% elif model_provider.value == "dashscope" %}
    model: {{ dashscope_model | default("qwen-max") }}
    {% elif model_provider.value == "anthropic" %}
    model: {{ anthropic_model | default("claude-3-5-sonnet-20241022") }}
    {% elif model_provider.value == "gemini" %}
    model: {{ gemini_model | default("gemini-pro") }}
    {% endif %}
    memory_type: {{ memory_type.value }}
    system_prompt: |
      You are a browser automation agent specialized in web interaction.

models:
  {{ model_provider.value }}:
    {% if model_provider.value == "openai" %}
    api_key_env: "OPENAI_API_KEY"
    model: {{ openai_model | default("gpt-4") }}
    {% elif model_provider.value == "dashscope" %}
    api_key_env: "DASHSCOPE_API_KEY"
    model: {{ dashscope_model | default("qwen-max") }}
    {% elif model_provider.value == "anthropic" %}
    api_key_env: "ANTHROPIC_API_KEY"
    model: {{ anthropic_model | default("claude-3-5-sonnet-20241022") }}
    {% elif model_provider.value == "gemini" %}
    api_key_env: "GEMINI_API_KEY"
    model: {{ gemini_model | default("gemini-pro") }}
    {% endif %}

browser:
  headless: {{ browser_headless | default(false) }}
  timeout: {{ browser_timeout | default(30000) }}
  screenshot_dir: {{ screenshot_dir | default("./screenshots") }}

tools:
  - name: browser_navigate
    enabled: true
  - name: browser_click
    enabled: true
  - name: browser_type
    enabled: true
  - name: browser_screenshot
    enabled: true
  - name: browser_extract
    enabled: true
  - name: browser_scroll
    enabled: true
