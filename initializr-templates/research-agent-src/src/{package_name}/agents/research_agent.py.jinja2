"""
Research agent implementation.
"""

import httpx
from typing import List, Dict
from agentscope.agent import ReActAgent
from {{ package_name }}.config import get_model, get_memory, get_toolkit


class ResearchAgent:
    """
    Research agent specialized in finding and synthesizing information.
    """

    def __init__(self):
        """Initialize the research agent."""
        self.model = get_model()
        self.memory = get_memory()
        self.toolkit = get_toolkit()

        self.agent = ReActAgent(
            name="ResearchAgent",
            sys_prompt="""
            You are a research agent specialized in finding and synthesizing information.
            Your capabilities include:
            - Searching for current information
            - Analyzing multiple sources
            - Synthesizing findings into coherent reports
            - Citing sources appropriately
            """,
            model=self.model,
            memory=self.memory,
            toolkit=self.toolkit,
        )

    async def research(self, query: str) -> str:
        """
        Perform research on the given query.

        Args:
            query: Research query

        Returns:
            Research results
        """
        # Step 1: Analyze the research request
        analysis = await self.agent(
            f"Analyze this research request and identify key information needed: {query}"
        )

        # Step 2: Search for information
        search_results = await self._search_information(query)

        # Step 3: Analyze and synthesize findings
        synthesis = await self.agent(
            f"Synthesize these search results into a comprehensive report:\n"
            f"Analysis: {analysis}\n"
            f"Search Results: {search_results}\n"
            f"Original Query: {query}"
        )

        return synthesis

    async def _search_information(self, query: str) -> str:
        """
        Search for information using available tools.

        Args:
            query: Search query

        Returns:
            Search results
        """
        # This would integrate with Tavily or other search APIs
        # For now, return a placeholder
        return f"Search results for: {query}"
