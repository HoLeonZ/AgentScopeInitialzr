import asyncio
import os
from dotenv import load_dotenv

from {{ package_name }}.config import settings, get_model, get_memory, get_toolkit
from {{ package_name }}.agents.research_agent import ResearchAgent

# Load environment variables
load_dotenv()


async def main():
    """Main entry point for research agent."""
    # Initialize research agent
    agent = ResearchAgent()

    # Start interaction
    print(f"🔍 {{ name }} Research Agent is ready! Type 'exit' to quit.")
    print(f"   Agent Type: {{ agent_type.value }}")
    print(f"   Model Provider: {{ model_provider.value }}")
    print(f"   Capabilities: Web search, information synthesis, source analysis")
    print()

    while True:
        try:
            user_input = input("\\nYou: ")
            if user_input.lower() in ['exit', 'quit']:
                print("Goodbye!")
                break

            print(f"\\n🔍 Researching: {user_input}")
            response = await agent.research(user_input)
            print(f"\\nResearch Result: {response}")

        except KeyboardInterrupt:
            print("\\nGoodbye!")
            break
        except Exception as e:
            print(f"\\nError: {{ e }}")


if __name__ == "__main__":
    asyncio.run(main())
