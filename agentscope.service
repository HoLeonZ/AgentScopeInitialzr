[Unit]
Description=AgentScope Initializr Web Service
Documentation=https://github.com/your-repo/agentscope-initializr
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/agentscope-initializr
ExecStartPre=/bin/sleep 2
ExecStart=/usr/bin/docker-compose -f docker-compose.arm64.yml up -d
ExecStop=/usr/bin/docker-compose -f docker-compose.arm64.yml down
ExecReload=/usr/bin/docker-compose -f docker-compose.arm64.yml restart
TimeoutStartSec=120
TimeoutStopSec=60
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
